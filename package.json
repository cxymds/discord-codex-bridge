{
  "name": "discord-codex-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/src/index.js",
    "service:install": "node scripts/launchd-service.mjs install",
    "service:uninstall": "node scripts/launchd-service.mjs uninstall",
    "service:start": "node scripts/launchd-service.mjs start",
    "service:stop": "node scripts/launchd-service.mjs stop",
    "service:restart": "node scripts/launchd-service.mjs restart",
    "service:status": "node scripts/launchd-service.mjs status",
    "test": "vitest run",
    "test:watch": "vitest",
    "notify": "node scripts/codex-discord-notify.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "discord.js": "^14.18.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "https-proxy-agent": "^7.0.6",
    "nanoid": "^5.0.9",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
